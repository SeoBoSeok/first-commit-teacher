# 환경변수 키 목록 — 값은 .env.local에만 (절대 커밋 금지)
# 새 환경변수를 쓰게 되면 여기에 키 이름을 추가할 것

# next-auth
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Discord OAuth (선택)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Stripe (테스트 모드 키만!)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 인증 메일 (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Postgres (Neon — Vercel 마켓플레이스로 연결하면 자동 주입)
DATABASE_URL=
